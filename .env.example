# .env.example — copy this to .env and fill in real values before running.
#
# HOW IT WORKS:
#   Pydantic Settings (app/core/config.py) reads these variables at startup.
#   Variables in .env override the defaults in Settings, which in turn are
#   overridden by environment variables set directly in docker-compose.yml.
#   Priority (highest → lowest): shell env > .env > Settings defaults
#
# SECURITY: Never commit .env to git. It contains secrets. .env.example is
# safe to commit because it has no real values.

# === App ===
SECRET_KEY=change-me-to-random-string   # used for signing tokens — must be random in production
DEBUG=False                              # True enables SQL query logging and debug tracebacks
# Pydantic Settings requires JSON array format for list fields
ALLOWED_ORIGINS=["https://docforge.nstoug.com","http://localhost:5173"]

# === Database ===
# These individual vars are used by docker-compose.yml to initialise Postgres.
# DATABASE_URL is the full connection string consumed by SQLAlchemy.
# asyncpg is the async Postgres driver — required for async SQLAlchemy.
POSTGRES_DB=docforge_db
POSTGRES_USER=docforge_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=db        # Docker service name — resolves to the postgres container
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# === Redis ===
# Redis is used for async job queuing (Stage 4+). The URL format is:
#   redis://<host>:<port>/<db-number>
REDIS_URL=redis://redis:6379/0

# === LLM Providers ===
# DocForge routes all LLM calls through OpenRouter — a single API that gives
# access to models from Anthropic, OpenAI, Google, and others.
# Get a key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# BYOK (Bring Your Own Key): users can optionally pass their own API key in
# the extraction request. If they do, that key is used instead of the server
# key below. Direct provider keys are reserved for future fallback routing.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# === Rate Limiting (demo) ===
# In demo mode, unauthenticated users are limited to this many extractions/hour.
# DEMO_ALLOWED_MODELS restricts which models they can select.
DEMO_RATE_LIMIT_PER_HOUR=10
DEMO_ALLOWED_MODELS=["anthropic/claude-sonnet-4-20250514","google/gemini-2.0-flash-001","openai/gpt-4o-mini","openai/gpt-5.4-nano"]
